# .env.example — Ofertas Reales IA
#
# Copia este archivo a `.env.local` (desarrollo) y configura los valores reales
# en el entorno de despliegue (Vercel/Supabase). Este archivo SE VERSIONA, así
# que NUNCA debe contener valores reales de secretos (R27.1, R27.5).
#
# Reglas de seguridad (R27.2):
# - Los secretos del servidor JAMÁS usan el prefijo `NEXT_PUBLIC_`.
# - Las variables `NEXT_PUBLIC_*` se incrustan en el bundle del navegador:
#   nunca coloques un secreto en una variable `NEXT_PUBLIC_*`.
# - La validación de arranque (`lib/env.ts`, `lib/env.server.ts`) aborta el
#   despliegue en producción si falta una variable requerida, listando solo
#   los NOMBRES de las variables, nunca sus valores (R27.3, R27.4, R27.5).

# ──────────────────────────────────────────────────────────────────────────
# Público (NEXT_PUBLIC_*) — visible en el navegador. NUNCA secretos.
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://programadormx.online
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_WHATSAPP_INVITE_URL=https://chat.whatsapp.com/LoPk1kbvquFAA8xG8MXRDS

# ──────────────────────────────────────────────────────────────────────────
# Solo servidor — sin prefijo NEXT_PUBLIC_, nunca llega al cliente.
# ──────────────────────────────────────────────────────────────────────────
# Secretos: déjalos VACÍOS aquí; configúralos en el entorno de despliegue.
SUPABASE_SERVICE_ROLE_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
CRON_SECRET=

# Allowlist de administradores (uno o varios correos separados por coma).
# Específico del despliegue: déjalo vacío en el ejemplo.
ADMIN_EMAIL=

# No secretos: valores seguros por defecto para el servidor.
TELEGRAM_ALLOWED_CHAT_ID=5054325626
AMAZON_TRACKING_ID=programadormx-20
SHOW_AMAZON_PRICES=true

# Quick-offer REST endpoint — omit or leave empty to disable
QUICK_OFFER_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Solo build (NO runtime de producción).
# ──────────────────────────────────────────────────────────────────────────
# SKIP_ENV_VALIDATION: úsalo SOLO en tiempo de compilación (`next build`) cuando
# el entorno de build no tiene secretos reales (p. ej. imágenes de CI o un
# checkout limpio). Cuando es "truthy" (1/true/yes/on), la validación de entorno
# NO aborta el build aunque falten variables; cae al mismo comportamiento que
# fuera de producción y solo registra los NOMBRES faltantes (R27.5).
# NO lo definas en el runtime de producción: ahí el fallo rápido por una
# variable faltante es el comportamiento deseado (R27.4).
# SKIP_ENV_VALIDATION=
